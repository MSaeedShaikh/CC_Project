# ── Flask ────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
BASE_URL=http://YOUR_LOAD_BALANCER_IP   # update after deploy step 8

# ── Database ─────────────────────────────────────────
# For GCP: set DATABASE_URL explicitly using the TCP IP printed by cloud-sql-setup.ps1
# e.g. DATABASE_URL=postgresql://urluser:pass@34.x.x.x/urlshortener
# For local dev: leave DATABASE_URL blank — falls back to SQLite
DATABASE_URL=
DB_NAME=urlshortener
DB_USER=urluser
DB_PASS=your-db-password

# ── GCP ───────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
